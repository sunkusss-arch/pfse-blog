---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const CATEGORY_COLORS: Record<string, string> = {
  '자산군': '#E84040',
  '재무개념': '#2563EB',
  '사용가이드': '#10B981',
  '시장분석': '#F59E0B',
};
const categoryColor = CATEGORY_COLORS[post.data.category] || '#E84040';

const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id && p.data.category === post.data.category)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const toolUrl = 'https://heroic-emotion-production-8c12.up.railway.app';
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  ogImage={post.data.heroImage}
  pubDate={post.data.pubDate}
  tags={post.data.tags}
>
  <article>
    <header class="mb-10 border-b border-gray-200 pb-8">
      <p class="text-sm font-medium" style={`color: ${categoryColor}`}>{post.data.category}</p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-gray-900 md:text-4xl">
        {post.data.title}
      </h1>
      <p class="mt-4 text-lg text-gray-600">{post.data.description}</p>
      <div class="mt-6 flex flex-wrap items-center gap-3 text-sm text-gray-500">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('ko-KR', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        {
          post.data.updatedDate && (
            <span>
              수정{' '}
              <time datetime={post.data.updatedDate.toISOString()}>
                {post.data.updatedDate.toLocaleDateString('ko-KR')}
              </time>
            </span>
          )
        }
      </div>
      {
        post.data.tags.length > 0 && (
          <ul class="mt-6 flex flex-wrap gap-2" aria-label="태그">
            {post.data.tags.map((tag) => (
              <li>
                <span class="rounded-full bg-gray-100 px-3 py-1 text-xs text-gray-700">
                  {tag}
                </span>
              </li>
            ))}
          </ul>
        )
      }
    </header>

    <div
      class="post-body max-w-none text-gray-800 leading-relaxed
        [&_h2]:mt-10 [&_h2]:mb-3 [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-gray-900
        [&_h3]:mt-8 [&_h3]:mb-2 [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:text-gray-900
        [&_p]:mb-4 [&_a]:text-[#E84040] [&_a]:underline [&_a]:underline-offset-2 hover:[&_a]:text-[#c93636]
        [&_ul]:mb-4 [&_ul]:list-disc [&_ul]:pl-6
        [&_ol]:mb-4 [&_ol]:list-decimal [&_ol]:pl-6
        [&_li]:mb-1
        [&_blockquote]:my-4 [&_blockquote]:border-l-4 [&_blockquote]:border-gray-200 [&_blockquote]:pl-4 [&_blockquote]:text-gray-600
        [&_pre]:my-4 [&_pre]:overflow-x-auto [&_pre]:rounded-lg [&_pre]:bg-gray-900 [&_pre]:p-4 [&_pre]:text-sm [&_pre]:text-gray-100
        [&_code]:rounded [&_code]:bg-gray-100 [&_code]:px-1 [&_code]:py-0.5 [&_code]:text-[0.9em] [&_code]:text-gray-800
        [&_pre_code]:bg-transparent [&_pre_code]:p-0 [&_pre_code]:text-inherit
        [&_img]:my-6 [&_img]:max-h-[480px] [&_img]:w-auto [&_img]:max-w-full [&_img]:rounded-lg [&_img]:border [&_img]:border-gray-100
        [&_table]:my-4 [&_table]:w-full [&_table]:border-collapse [&_table]:text-sm
        [&_th]:border [&_th]:border-gray-200 [&_th]:bg-gray-50 [&_th]:px-3 [&_th]:py-2 [&_th]:text-left [&_th]:font-semibold
        [&_td]:border [&_td]:border-gray-200 [&_td]:px-3 [&_td]:py-2"
      aria-label="본문"
    >
      <Content />
    </div>

    <section
      class="mt-12 rounded-lg border border-[#E84040]/20 bg-[#E84040]/5 px-6 py-8"
      aria-labelledby="post-cta-heading"
    >
      <h2 id="post-cta-heading" class="text-lg font-semibold text-gray-900">
        PFSE 도구로 직접 시뮬레이션해보기
      </h2>
      <p class="mt-2 text-sm text-gray-600">
        블로그에서 다룬 개념을 PFSE 웹 도구에서 숫자로 확인해 보실 수 있습니다.
      </p>
      <a
        href={toolUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 inline-flex items-center rounded-md bg-[#E84040] px-4 py-2.5 text-sm font-medium text-white transition hover:bg-[#c93636]"
      >
        PFSE 도구 열기
      </a>
    </section>

    {
      relatedPosts.length > 0 && (
        <section class="mt-14" aria-labelledby="related-heading">
          <h2 id="related-heading" class="text-xl font-bold text-gray-900">
            같은 카테고리의 다른 글
          </h2>
          <ul class="mt-6 space-y-4">
            {relatedPosts.map((p) => (
              <li>
                <a
                  href={`/blog/${p.id}`}
                  class="group block rounded-lg border border-gray-200 p-4 transition hover:border-[#E84040]/40 hover:bg-gray-50"
                >
                  <span class="text-xs" style={`color: ${categoryColor}`}>{p.data.category}</span>
                  <span class="mt-1 block font-medium text-gray-900 group-hover:text-[#E84040]">
                    {p.data.title}
                  </span>
                  <time
                    class="mt-2 block text-xs text-gray-400"
                    datetime={p.data.pubDate.toISOString()}
                  >
                    {p.data.pubDate.toLocaleDateString('ko-KR')}
                  </time>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</BaseLayout>
