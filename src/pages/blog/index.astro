---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const CATEGORIES = ['자산군', '재무개념', '사용가이드', '시장분석'] as const;

const CATEGORY_COLORS: Record<string, string> = {
  '자산군': '#E84040',
  '재무개념': '#2563EB',
  '사용가이드': '#10B981',
  '시장분석': '#F59E0B',
};

const posts = await getCollection('blog');
const sortedPosts = [...posts].sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// 색상까지 미리 매핑해서 JSX는 단순하게 유지
const postsWithColor = sortedPosts.map((post) => ({
  post,
  color: CATEGORY_COLORS[post.data.category] || '#E84040',
}));
---

<BaseLayout
  title="블로그"
  description="PFSE 블로그에서 자산군, 재무 개념, 사용 가이드, 시장 분석 글을 확인하세요."
>
  <header class="mb-10">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900">블로그</h1>
    <p class="mt-2 text-gray-600">
      정보 제공 목적의 글입니다. 투자 권유나 자문이 아닙니다.
    </p>
  </header>

  {
    sortedPosts.length === 0 ? (
      <p class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-8 text-center text-gray-600">
        아직 작성된 글이 없습니다.
      </p>
    ) : (
      <>
        <nav class="mb-8 flex flex-wrap gap-2" aria-label="카테고리 필터">
            <a
            href="/blog"
            class="filter-pill rounded-full border border-gray-200 px-4 py-2 text-sm text-gray-700 transition hover:border-[#E84040] hover:text-[#E84040]"
            data-filter-link=""
            data-category=""
          >
            전체
          </a>
          {CATEGORIES.map((cat) => (
              <a
              href={`/blog?category=${encodeURIComponent(cat)}`}
              class="filter-pill rounded-full border border-gray-200 px-4 py-2 text-sm text-gray-700 transition hover:border-[#E84040] hover:text-[#E84040]"
              data-filter-link=""
              data-category={cat}
            >
              {cat}
            </a>
          ))}
        </nav>

        <div
          class="grid grid-cols-1 gap-6 sm:grid-cols-2"
          data-blog-grid
        >
          {postsWithColor.map(({ post, color }) => (
            <a
              href={`/blog/${post.id}`}
              class="group flex flex-col overflow-hidden rounded-lg border border-gray-200 bg-white transition hover:shadow-md"
              style={`border-top: 3px solid ${color}`}
              data-post-card
              data-category={post.data.category}
            >
              <div class="flex flex-1 flex-col p-6">
                <div class="flex items-center gap-2">
                  <span
                    class="inline-block h-2 w-2 rounded-full"
                    style={`background-color: ${color}`}
                  />
                  <span
                    class="text-xs font-medium"
                    style={`color: ${color}`}
                  >
                    {post.data.category}
                  </span>
                </div>
                <h2 class="mt-3 text-xl font-semibold text-gray-900 transition group-hover:opacity-80">
                  {post.data.title}
                </h2>
                <p class="mt-3 line-clamp-3 flex-1 text-sm leading-relaxed text-gray-600">
                  {post.data.description}
                </p>
                <time
                  class="mt-5 text-xs text-gray-400"
                  datetime={post.data.pubDate.toISOString()}
                >
                  {post.data.pubDate.toLocaleDateString('ko-KR')}
                </time>
              </div>
            </a>
          ))}
        </div>

        <p
          id="blog-empty-filtered"
          hidden
          class="mt-8 rounded-lg border border-gray-200 bg-gray-50 px-4 py-8 text-center text-gray-600"
          role="status"
        >
          선택한 카테고리에 표시할 글이 없습니다.
        </p>

        <script is:inline>
          (function () {
            var VALID = ['자산군', '재무개념', '사용가이드', '시장분석'];

            function syncBlogCategoryFilter() {
              var params = new URLSearchParams(window.location.search);
              var raw = params.get('category');
              var category = raw && VALID.indexOf(raw) !== -1 ? raw : null;

              document.querySelectorAll('[data-post-card]').forEach(function (card) {
                var cat = card.getAttribute('data-category') || '';
                var show = !category || cat === category;
                card.hidden = !show;
              });

              var visible = 0;
              document.querySelectorAll('[data-post-card]').forEach(function (card) {
                if (!card.hidden) visible += 1;
              });

              var emptyEl = document.getElementById('blog-empty-filtered');
              if (emptyEl) {
                emptyEl.hidden = !(category && visible === 0);
              }

              document.querySelectorAll('[data-filter-link]').forEach(function (link) {
                var linkCat = link.getAttribute('data-category') || '';
                var isActive = category ? linkCat === category : linkCat === '';
                if (isActive) {
                  link.setAttribute('aria-current', 'page');
                  link.classList.add(
                    'border-[#E84040]',
                    'bg-[#E84040]/5',
                    'text-[#E84040]',
                    'font-medium',
                  );
                } else {
                  link.removeAttribute('aria-current');
                  link.classList.remove(
                    'border-[#E84040]',
                    'bg-[#E84040]/5',
                    'text-[#E84040]',
                    'font-medium',
                  );
                }
              });
            }

            syncBlogCategoryFilter();
            window.addEventListener('popstate', syncBlogCategoryFilter);
          })();
        </script>
      </>
    )
  }
</BaseLayout>
